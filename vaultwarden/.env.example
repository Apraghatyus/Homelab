# === Vaultwarden ===
# Token de acceso al panel /admin (generar con: openssl rand -base64 48)
ADMIN_TOKEN=tu-token-generado-con-openssl-rand-base64-48

# Zona horaria
TZ=America/Bogota

# Registro de nuevos usuarios (false después de crear las cuentas)
SIGNUPS_ALLOWED=false

# Sincronización en tiempo real entre clientes
WEBSOCKET_ENABLED=true

# Rate Limiting - Login (Web Vault)
LOGIN_RATELIMIT_MAX_BURST=5
LOGIN_RATELIMIT_SECONDS=60

# Rate Limiting - Admin Panel (/admin)
ADMIN_RATELIMIT_MAX_BURST=3
ADMIN_RATELIMIT_SECONDS=60