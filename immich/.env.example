# Immich — Homelab Apraghatyus
# Fase 4 — Media y Entretenimiento

# Librería de fotos/videos — almacenada en NAS vía NFS (RAID 1)
UPLOAD_LOCATION=/mnt/nas/photos/immich

# Base de datos PostgreSQL — DEBE ser disco local (SSD), NO network share
DB_DATA_LOCATION=/home/apraghatyus/homelab/immich/postgres

# Zona horaria
TZ=America/Bogota

# Versión de Immich — v2 sigue la última major release
IMMICH_VERSION=v2

# PostgreSQL
DB_PASSWORD=CHANGE_ME
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
